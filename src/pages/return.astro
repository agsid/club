---
import { env } from "cloudflare:workers";
import Stripe from 'stripe';

const sessionId = Astro.url.searchParams.get('session_id');
let status = "loading";

if (sessionId) {
    const stripe = new Stripe(env.STRIPE_SECRET_KEY);
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    status = session.status === 'complete' ? 'success' : 'pending';
}
---

<div class="min-h-screen bg-white flex items-center justify-center p-10 text-center">
    <div>
        {status === 'success' ? (
            <>
                <div class="text-6xl mb-4">🎉</div>
                <h1 class="text-3xl font-bold">Payment Successful!</h1>
                <p class="text-slate-500 mt-2">Welcome to the club. Check your inbox for your member guide.</p>
            </>
        ) : (
            <p>Processing payment...</p>
        )}
        <a href="/" class="mt-8 inline-block text-blue-600 font-medium">Return to Dashboard</a>
    </div>
</div>